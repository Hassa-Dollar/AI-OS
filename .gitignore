
node_modules/
dist/
coverage/
reports/metrics/ledger.csv

# worker / verifier run logs (OS-V1 / ADR-0026 §4) — appended by dispatch.sh + gate.sh; never commit
logs/

# Python bytecode (the scripts/os CLI is stdlib Python, ADR-0023); never commit
__pycache__/
*.pyc

# local QA artifacts (generated by gate.sh, not source)
reviews/verdicts/*
!reviews/verdicts/.gitkeep
reviews/queue/*
!reviews/queue/.gitkeep

# secrets + local runtime (Shrink) — never commit; .env.example documents the keys (ADR-0011)
.env
.env.*
!.env.example
*.db
*.db-shm
*.db-wal
