#!/usr/bin/env bash
# pre-push gate — runs the same checks as CI so a red commit never leaves your machine.
# Checks every component under components/<name>/ in its own directory (ADR-0002).
# Activate once:
#   git config core.hooksPath .githooks
#   chmod +x .githooks/pre-push
set -euo pipefail

shopt -s nullglob
comps=( components/*/ )
[[ ${#comps[@]} -gt 0 ]] || { echo "[pre-push] no components/ — nothing to check"; exit 0; }
for c in "${comps[@]}"; do
  [[ -f "${c}package.json" ]] || continue
  echo "[pre-push] ${c}lint";      ( cd "$c" && npm run lint )
  echo "[pre-push] ${c}typecheck"; ( cd "$c" && npm run typecheck )
  echo "[pre-push] ${c}tests";     ( cd "$c" && npm test )
done
echo "[pre-push] ✓ green — allowing push"
