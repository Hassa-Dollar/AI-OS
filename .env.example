# Shrink — environment TEMPLATE. Copy to .env (gitignored) and fill TEST values. NEVER commit real keys;
# gitleaks (os-ci) blocks secret commits. Values are intentionally blank here — formats shown in comments.

# ── API (components/api) ────────────────────────────────────────────────
BETTER_AUTH_SECRET=        # long random string — generate: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:8787
DATABASE_PATH=./shrink.db  # SQLite file (gitignored)
BASE_URL=http://localhost:8787      # used to build short URLs (e.g. http://localhost:8787/<code>)
WEB_ORIGIN=http://localhost:5173    # CORS allow-origin (the web dev server)
STRIPE_SECRET_KEY=         # Stripe TEST secret  (format: sk_test_…)
STRIPE_WEBHOOK_SECRET=     # from `stripe listen` (format: whsec_…)
STRIPE_PRICE_ID=           # Pro plan price id, TEST mode (format: price_…)

# ── Web (components/web) ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8787
VITE_STRIPE_PUBLISHABLE_KEY=        # publishable, NOT secret (format: pk_test_…)
