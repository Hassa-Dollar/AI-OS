{
  "name": "@shrink/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shrink HTTP API (Hono on Node 22).",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "ci": "npm run -s lint && npm run -s typecheck && npm run -s test && npm run -s coverage && npm audit --omit=dev --audit-level=high",
    "dev": "tsx watch src/server.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^12.11.1",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
